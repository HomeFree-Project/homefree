+######################################################################
+## nic_hetznercloud_examples
+######################################################################
+sub nic_hetznercloud_examples {
+    return <<"EoEXAMPLE";
+o 'hetznercloud'
+
+The 'hetznercloud' protocol is used by the Cloud DNS service offered by www.hetzner.com.
+This is the newer Hetzner Cloud API (api.hetzner.cloud), not the legacy dns.hetzner.com API.
+
+Configuration variables applicable to the 'hetznercloud' protocol are:
+  protocol=hetznercloud        ##
+  server=fqdn.of.service       ## defaults to api.hetzner.cloud/v1
+  zone=dns.zone                ## the DNS zone to update
+  password=api-token           ## API token from Hetzner Cloud Console
+  fully.qualified.host         ## the host registered with the service.
+
+Example ddclient.conf file entries:
+  protocol=hetznercloud                                        \\
+  zone=example.com                                             \\
+  password=my-hetzner-cloud-api-token                          \\
+  myhost.example.com
+EoEXAMPLE
+}
+
+######################################################################
+## nic_hetznercloud_update
+######################################################################
+sub nic_hetznercloud_update {
+    debug("\nnic_hetznercloud_update -------------------");
+
+    my %groups = group_hosts_by([ @_ ], [ qw(ssh login password server wildcard mx backupmx zone) ]);
+
+    foreach my $sig (keys %groups) {
+        my @hosts = @{$groups{$sig}};
+        my $key   = $hosts[0];
+
+        my $headers = "Authorization: Bearer $config{$key}{'password'}\n";
+        $headers .= "Content-Type: application/json";
+
+        for my $domain (@hosts) {
+            (my $hostname = $domain) =~ s/\.$config{$key}{zone}$//;
+            my $ipv4 = delete $config{$domain}{'wantipv4'};
+            my $ipv6 = delete $config{$domain}{'wantipv6'};
+
+            info("getting Hetzner Cloud Zone ID for %s", $domain);
+
+            my $url = "https://$config{$key}{'server'}/zones?name=" . $config{$key}{'zone'};
+            my $reply = geturl(proxy => opt('proxy'), url => $url, headers => $headers);
+            unless ($reply && header_ok($domain, $reply)) {
+                failed("updating %s: Could not connect to %s.", $domain, $config{$key}{'server'});
+                next;
+            }
+
+            $reply =~ qr/{(?:[^{}]*|(?R))*}/mp;
+            my $response = eval {decode_json(${^MATCH})};
+            unless ($response && $response->{zones}) {
+                failed("updating %s: invalid json or result.", $domain);
+                next;
+            }
+
+            my ($zone_id) = map {$_->{name} eq $config{$key}{'zone'} ? $_->{id} : ()} @{$response->{zones}};
+            unless ($zone_id) {
+                failed("updating %s: No zone ID found for %s.", $domain, $config{$key}{'zone'});
+                next;
+            }
+            info("Zone ID is %s", $zone_id);
+
+            foreach my $ip ($ipv4, $ipv6) {
+                next if (!$ip);
+                my $ipv  = ($ip eq ($ipv6 // '')) ? '6' : '4';
+                my $type = ($ip eq ($ipv6 // '')) ? 'AAAA' : 'A';
+
+                info("updating %s: setting IPv$ipv address to %s", $domain, $ip);
+                $config{$domain}{"status-ipv$ipv"} = 'failed';
+
+                # Hetzner Cloud API requires DELETE + POST to update (PUT doesn't work)
+                # First DELETE existing record (ignore 404 if it doesn't exist)
+                $url = "https://$config{$key}{'server'}/zones/$zone_id/rrsets/$hostname/$type";
