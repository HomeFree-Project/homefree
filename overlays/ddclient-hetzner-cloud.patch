+                debug("updating %s: POST to %s with data: %s", $domain, $url, $data);
+
+                $reply = geturl(proxy => opt('proxy'), url => $url, headers => $headers, method => "POST", data => $data);
+                unless ($reply && header_ok($domain, $reply)) {
+                    failed("updating %s: Could not create rrset at %s.", $domain, $config{$key}{'server'});
+                    next;
+                }
+
